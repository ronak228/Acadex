# ==========================================
# EduERP Server Configuration Template
# ==========================================

# 1. System Runtime Mode
# Options: development, production, test
NODE_ENV=development

# 2. Server Port Configuration
# The port the Express application server will listen on.
PORT=5001

# 3. Database Connection URI
# Prisma connection URL formatting for PostgreSQL database.
# Syntax: postgresql://[user]:[password]@[host]:[port]/[database_name]?schema=[schema_name]
DATABASE_URL="postgresql://postgres:your_secure_password@localhost:5432/edu_erp?schema=public"

# 4. JSON Web Token Cryptography (Authentication)
# Secure key used to sign and verify JWT authentication tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="REPLACE_WITH_RANDOM_SECRET"

# Token lifespan. Duration formats: e.g., '1h', '7d', '24h', '30m'
JWT_EXPIRES_IN="7d"

# 5. Security & CORS (Cross-Origin Resource Sharing)
# Whitelist of client URLs permitted to access these APIs.
CORS_ORIGIN="http://localhost:5173"
